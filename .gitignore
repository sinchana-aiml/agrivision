# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates want to use a different version of python,
#   Pipfile.lock may cause conflict.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is of version-specific nature and should be ignored
#   if you are developing a library.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is of version-specific nature and should be ignored
#   if you are developing a library.
# pdm.lock

